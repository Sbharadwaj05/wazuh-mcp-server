# Wazuh MCP Server Configuration
# Copy this file to .env and fill in your Wazuh manager details

# ---- Required: Wazuh API ----
WAZUH_API_URL=https://your-wazuh-manager:55000
WAZUH_USERNAME=wazuh-wui
WAZUH_PASSWORD=your-api-password

# ---- Required for Alerts/Vulnerabilities/Rules (Wazuh 4.x/5.x) ----
# The Wazuh Indexer stores alerts, vulnerabilities, and events.
# By default it only listens on localhost — you must expose it on the network.
# See docs/TROUBLESHOOTING.md for the one-line fix.
WAZUH_INDEXER_URL=https://your-wazuh-manager:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=your-indexer-password

# ---- Optional ----
# Set to "true" to skip TLS verification (not recommended for production)
WAZUH_INSECURE=false

# RBAC role: viewer, analyst, admin, or soc (leave empty for all tools)
WAZUH_RBAC_ROLE=

# Prometheus metrics port (0 to disable)
WAZUH_METRICS_PORT=9090

# Rate limiting: max burst requests per tool
# WAZUH_RATE_LIMIT_TOKENS=30
# Rate limiting: refill window in seconds
# WAZUH_RATE_LIMIT_PERIOD=60

# API request timeout in seconds
WAZUH_TIMEOUT=30

# Audit log location
# WAZUH_AUDIT_LOG=~/.wazuh-mcp/audit.jsonl
