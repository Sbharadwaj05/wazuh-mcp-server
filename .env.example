# Wazuh MCP Server Configuration
# Copy this file to .env and fill in your Wazuh manager details

WAZUH_API_URL=https://your-wazuh-manager:55000
WAZUH_USERNAME=admin
WAZUH_PASSWORD=your-password-here

# Optional: Set to "true" to skip TLS verification (not recommended for production)
WAZUH_INSECURE=false

# Optional: API request timeout in seconds
WAZUH_TIMEOUT=30

# Optional: RBAC role (viewer, analyst, admin, soc)
WAZUH_RBAC_ROLE=

# Optional: Prometheus metrics port (0 to disable)
WAZUH_METRICS_PORT=9090

# Optional: Rate limiting
# WAZUH_RATE_LIMIT_TOKENS=30
# WAZUH_RATE_LIMIT_PERIOD=60
